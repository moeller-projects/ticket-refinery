{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["facts", "classes", "api_specs", "unknowns", "sourceRefs"],
  "properties": {
    "facts": { "type": "array", "items": { "type": "string" } },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "fields", "methods", "relationships", "sourceRef"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "enum": ["class", "interface", "contract"] },
          "visibility": { "type": "string" },
          "abstract": { "type": "boolean" },
          "extends": { "type": ["string", "null"] },
          "implements": { "type": "array", "items": { "type": "string" } },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "visibility": { "type": "string" },
                "optional": { "type": "boolean" },
                "default": {},
                "description": { "type": "string" }
              }
            }
          },
          "methods": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "parameters", "returns"],
              "properties": {
                "name": { "type": "string" },
                "visibility": { "type": "string" },
                "parameters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" },
                      "optional": { "type": "boolean" }
                    }
                  }
                },
                "returns": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "target"],
              "properties": {
                "type": {
                  "enum": ["extends", "implements", "association", "dependency", "aggregation", "composition"]
                },
                "target": { "type": "string" },
                "label": { "type": "string" },
                "multiplicity": { "type": "string" }
              }
            }
          },
          "sourceRef": { "type": "string" }
        }
      }
    },
    "api_specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path", "sourceRef"],
        "properties": {
          "method": { "type": "string" },
          "path": { "type": "string" },
          "requestShape": { "type": "object" },
          "responseShape": { "type": "object" },
          "sourceRef": { "type": "string" }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "why"],
        "properties": {
          "question": { "type": "string" },
          "why": { "type": "string" }
        }
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggested_title": { "type": ["string", "null"] }
  }
}
