{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["facts", "dtos", "api_specs", "unknowns", "sourceRefs"],
  "properties": {
    "facts": { "type": "array", "items": { "type": "string" } },
    "dtos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "fields", "sourceRef"],
        "properties": {
          "name": { "type": "string" },
          "fields": { "type": "array", "items": { "type": "object" } },
          "sourceRef": { "type": "string" }
        }
      }
    },
    "api_specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path", "sourceRef"],
        "properties": {
          "method": { "type": "string" },
          "path": { "type": "string" },
          "requestShape": { "type": "object" },
          "responseShape": { "type": "object" },
          "sourceRef": { "type": "string" }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "why"],
        "properties": {
          "question": { "type": "string" },
          "why": { "type": "string" }
        }
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggested_title": { "type": ["string", "null"] }
  }
}
