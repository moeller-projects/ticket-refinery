# --- Azure DevOps ---
# ADO organization name
ADO_ORG=your-org
# ADO project name
ADO_PROJECT=your-project
# PAT scoped to Work Items Read&Write, Code Read only. Never commit.
# Leave empty if you use a Bearer token (recommended when the org
# disables PAT auth; see ADO_AUTH_TOKEN below).
ADO_PAT=

# Bearer token: used when ADO_PAT is empty. Priority order is fixed in code:
# 1) SYSTEM_ACCESSTOKEN (Azure Pipelines auto-injects this)
# 2) ADO_AUTH_TOKEN
# 3) ADO_MCP_AUTH_TOKEN
# 4) ADO_API_KEY
# Generate at https://dev.azure.com/<org>/_usersSettings/tokens
ADO_AUTH_TOKEN=

# --- Tags (must match tags actually used in ADO) ---
# tag that queues a work item for refinement
TAG_TRIGGER=needs-refinement
# tag applied when refinement succeeds with no unknowns
TAG_DONE=refinement-done
# tag applied when unknowns exist or validation fails
TAG_BLOCKED=refinement-blocked

# --- Behavior ---
# true to let the agent rewrite work item titles (off by default, risky)
ALLOW_TITLE_EDITS=false
# ADO custom field used to store the idempotency hash
MARKER_FIELD=Custom.RefinementMarker
# git clone depth for repo checkout
CLONE_DEPTH=1
# Language for posted comments and the refinement attachment.
TARGET_LANGUAGE=English

# --- Pi coding agent ---
# model Pi uses for refinement; override for complex batches
PI_MODEL=gpt-5.4-mini
# timeout for pi subprocess in seconds
PI_TIMEOUT_SECONDS=900

# --- Container runtime ---
# docker or podman; leave blank to auto-detect
CONTAINER_ENGINE=